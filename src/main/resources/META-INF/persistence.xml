<?xml version="1.0" encoding="UTF-8"?>
<persistence xmlns="https://jakarta.ee/xml/ns/persistence" version="3.0">
  <persistence-unit name="EduAssistPU" transaction-type="RESOURCE_LOCAL">
    <provider>org.hibernate.jpa.HibernatePersistenceProvider</provider>

    <!-- Classe d'entités scannées automatiquement si elles sont dans le classpath -->

    <!-- Propriétés JDBC (développement) :
         - createDatabaseIfNotExist=true permet de créer la base si l'utilisateur a les droits
         - hbm2ddl.auto=update met à jour le schéma (préférable en dev). Changez en 'validate' ou retirez en prod.
         Remplacez username/password par vos identifiants locaux ou configurez les via variables d'environnement. -->
    <properties>
      <property name="jakarta.persistence.jdbc.driver" value="com.mysql.cj.jdbc.Driver"/>
      <property name="jakarta.persistence.jdbc.url" value="jdbc:mysql://localhost:3300/eduassist_db?createDatabaseIfNotExist=true&serverTimezone=UTC"/>
      <property name="jakarta.persistence.jdbc.user" value="root"/>
      <property name="jakarta.persistence.jdbc.password" value="MOHSSINE2004"/>

      <!-- Hibernate-specific -->
      <property name="hibernate.dialect" value="org.hibernate.dialect.MySQL8Dialect"/>
      <property name="hibernate.hbm2ddl.auto" value="update"/>
      <property name="hibernate.show_sql" value="true"/>
      <property name="hibernate.format_sql" value="true"/>

      <!-- c3p0 pool (optional) -->
      <property name="hibernate.c3p0.min_size" value="5"/>
      <property name="hibernate.c3p0.max_size" value="20"/>
      <property name="hibernate.c3p0.timeout" value="300"/>
      <property name="hibernate.c3p0.max_statements" value="50"/>
    </properties>
  </persistence-unit>
</persistence>

